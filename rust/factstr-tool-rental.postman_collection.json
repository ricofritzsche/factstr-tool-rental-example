{
    "info": {
        "name": "FACTSTR Tool Rental API",
        "description": "Postman collection for testing the FACTSTR tool rental example API. It registers random tools, checks one out, returns it, and reads the inventory projection.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:3000",
            "type": "string"
        },
        {
            "key": "toolId",
            "value": "",
            "type": "string"
        },
        {
            "key": "serialNumber",
            "value": "",
            "type": "string"
        },
        {
            "key": "checkedOutTo",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Health",
            "request": {
                "method": "GET",
                "header": [],
                "url": {
                    "raw": "{{baseUrl}}/health",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "health"
                    ]
                }
            },
            "response": [],
            "event": [
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('health returns 200', function () {",
                            "  pm.response.to.have.status(200);",
                            "});"
                        ]
                    }
                }
            ]
        },
        {
            "name": "Register Random Tool",
            "event": [
                {
                    "listen": "prerequest",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "const suffix = Date.now() + '-' + Math.floor(Math.random() * 100000);",
                            "const tools = [",
                            "  { name: 'Cordless Drill', category: 'Power Tools', manufacturer: 'Bosch', model: 'GSR 18V' },",
                            "  { name: 'Angle Grinder', category: 'Power Tools', manufacturer: 'Makita', model: 'GA5030' },",
                            "  { name: 'Laser Measure', category: 'Measuring Tools', manufacturer: 'Leica', model: 'DISTO D2' },",
                            "  { name: 'Pipe Cutter', category: 'Plumbing Tools', manufacturer: 'RIDGID', model: 'RC-1625' },",
                            "  { name: 'Impact Driver', category: 'Power Tools', manufacturer: 'DeWalt', model: 'DCF887' }",
                            "];",
                            "const selected = tools[Math.floor(Math.random() * tools.length)];",
                            "pm.collectionVariables.set('serialNumber', 'SN-' + suffix);",
                            "pm.collectionVariables.set('toolName', selected.name);",
                            "pm.collectionVariables.set('toolCategory', selected.category);",
                            "pm.collectionVariables.set('manufacturer', selected.manufacturer);",
                            "pm.collectionVariables.set('model', selected.model);",
                            "pm.collectionVariables.set('homeLocation', 'Shelf-' + (1 + Math.floor(Math.random() * 20)));",
                            "pm.collectionVariables.set('initialCondition', 'usable');"
                        ]
                    }
                },
                {
                    "listen": "test",
                    "script": {
                        "type": "text/javascript",
                        "exec": [
                            "pm.test('register returns 201', function () {",
                            "  pm.response.to.have.status(201);",
                            "});",
                            "const body = pm.response.json();",
                            "pm.test('register response has tool_id and serial_number', function () {",
                            "  pm.expect(body.tool_id).to.be.a('string').and.not.empty;",
                            "  pm.expect(body.serial_number).to.eql(pm.collectionVariables.get('serialNumber'));",
                            "});",
                            "pm.collectionVariables.set('toolId', body.tool_id);"
                        ]
                    }
                }
            ],
            "request": {
                "method": "POST",
                "header": [
                    {
                        "key": "Content-Type",
                        "value": "application/json"
                    }
                ],
                "body": {
                    "mode": "raw",
                    "raw": "{\n  \"serial_number\": \"{{serialNumber}}\",\n  \"name\": \"{{toolName}}\",\n  \"category\": \"{{toolCategory}}\",\n  \"manufacturer\": \"{{manufacturer}}\",\n  \"model\": \"{{model}}\",\n  \"home_location\": \"{{homeLocation}}\",\n  \"initial_condition\": \"{{initialCondition}}\"\n}"
                },
                "url": {
                    "raw": "{{baseUrl}}/tools",
                    "host": [
                        "{{baseUrl}}"
                    ],
                    "path": [
                        "tools"
                    ]
                }
            },
            "response": []
        },
        {
            "name": "Register 5 Random Tools",
            "description": "Run this folder with the Collection Runner. It contains five independent random registration requests.",
            "item": [
                {
                    "name": "Register Random Tool 1",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"serial_number\": \"SN-{{$timestamp}}-{{$randomInt}}-1\",\n  \"name\": \"Cordless Drill\",\n  \"category\": \"Power Tools\",\n  \"manufacturer\": \"Bosch\",\n  \"model\": \"GSR 18V\",\n  \"home_location\": \"Shelf A\",\n  \"initial_condition\": \"usable\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/tools",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "tools"
                            ]
                        }
                    },
                    "response": []
                },
                {
                    "name": "Register Random Tool 2",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"serial_number\": \"SN-{{$timestamp}}-{{$randomInt}}-2\",\n  \"name\": \"Angle Grinder\",\n  \"category\": \"Power Tools\",\n  \"manufacturer\": \"Makita\",\n  \"model\": \"GA5030\",\n  \"home_location\": \"Shelf B\",\n  \"initial_condition\": \"usable\"\n}"
                        },
                        "url": {
                            "raw": "{{baseUrl}}/tools",
                            "host": [
                                "{{baseUrl}}"
                            ],
